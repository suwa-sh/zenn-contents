---
import Layout from '../../../layouts/Layout.astro';
import { loadBooks } from '../../../lib/books.mjs';

export async function getStaticPaths() {
  const books = loadBooks();
  return books.map((b) => ({ params: { slug: b.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<Layout title={book.title} ogImagePath={`og/books__${book.slug}.png`}>
  <p style="color:var(--muted)"><a href={`${base}books/`}>← Books</a></p>

  {!book.published && <p class="draft-badge">⚠️ 非公開（zenn 未公開）</p>}

  <div class="book-cover-area">
    {book.cover && <img class="book-cover-large" src={book.cover} alt="" />}
    <div>
      <h1>{book.title}</h1>
      <p>{book.summary}</p>
      <div class="article-meta">
        {book.publishedAt && <span>{book.publishedAt}</span>}
        {book.topics?.length > 0 && (
          <ul class="topic-list">
            {book.topics.map((t) => (
              <li><a href={`${base}tags/${encodeURIComponent(t)}/`}>#{t}</a></li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>

  <h2 class="section-title">目次</h2>
  <ol class="chapter-list">
    {book.chapters.map((c) => (
      <li>
        <a href={`${base}books/${book.slug}/${c.slug}/`}>{c.title}</a>
      </li>
    ))}
  </ol>
</Layout>
