---
import Layout from '../layouts/Layout.astro';
import { loadArticles } from '../lib/articles.mjs';

const articles = loadArticles();
const published = articles.filter((a) => a.published);
const drafts = articles.filter((a) => !a.published);
const base = import.meta.env.BASE_URL;
---
<Layout title="zenn-contents">
  <h1>Articles</h1>
  <p style="color:var(--muted)">
    zenn 用 Markdown を GitHub Pages で公開しているミラーです。zenn 本体の rate limit を回避するため、非公開記事も含めて全件公開しています。
  </p>
  <p>
    <a href={`${base}books/`}>📚 Books</a> ·
    <a href={`${base}tags/`}>🏷️ タグ一覧</a>
  </p>

  <h2 class="section-title">公開済み ({published.length})</h2>
  <ul class="article-list">
    {published.map((a) => (
      <li>
        <span class="emoji">{a.emoji}</span>
        <a href={`${base}articles/${a.slug}/`}>{a.title}</a>
        {a.publishedAt && <span class="date">{a.publishedAt}</span>}
      </li>
    ))}
  </ul>

  {drafts.length > 0 && (
    <>
      <h2 class="section-title">非公開 ({drafts.length})</h2>
      <ul class="article-list">
        {drafts.map((a) => (
          <li>
            <span class="emoji">{a.emoji}</span>
            <a href={`${base}articles/${a.slug}/`}>{a.title}</a>
            {a.publishedAt && <span class="date">{a.publishedAt}</span>}
          </li>
        ))}
      </ul>
    </>
  )}
</Layout>
